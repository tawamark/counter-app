<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/counter_surface"
    android:orientation="vertical">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@color/counter_background"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:padding="16dp">

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical">

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Contagens"
                android:textColor="@color/counter_text"
                android:textSize="22sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/text_user"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:textColor="@color/counter_muted"
                android:textSize="13sp" />
        </LinearLayout>

        <Button
            android:id="@+id/button_logout"
            android:layout_width="1dp"
            android:layout_height="1dp"
            android:background="@drawable/bg_button_secondary"
            android:minWidth="0dp"
            android:visibility="gone"
            android:text="Sair"
            android:textAllCaps="false"
            android:textColor="@color/counter_text" />
    </LinearLayout>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_margin="16dp"
        android:background="@drawable/bg_card"
        android:orientation="vertical"
        android:padding="16dp">

        <TextView
            android:id="@+id/text_summary_title"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Resumo"
            android:textColor="@color/counter_text"
            android:textSize="16sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/text_summary"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:textColor="@color/counter_muted"
            android:textSize="14sp" />

        <Button
            android:id="@+id/button_refresh"
            android:layout_width="1dp"
            android:layout_height="1dp"
            android:layout_marginTop="12dp"
            android:background="@drawable/bg_button_primary"
            android:visibility="gone"
            android:text="Atualizar"
            android:textAllCaps="false"
            android:textColor="@android:color/white" />
    </LinearLayout>

    <FrameLayout
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1">

        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/recycler_counts"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:clipToPadding="false"
            android:padding="16dp" />

        <LinearLayout
            android:id="@+id/layout_loading_counts"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:background="@color/counter_surface"
            android:gravity="center"
            android:orientation="vertical"
            android:padding="24dp"
            android:visibility="gone">

            <ProgressBar
                android:layout_width="44dp"
                android:layout_height="44dp"
                android:indeterminate="true" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:text="Atualizando contagens..."
                android:textColor="@color/counter_muted"
                android:textSize="14sp" />
        </LinearLayout>

        <LinearLayout
            android:id="@+id/layout_empty_counts"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:gravity="center"
            android:orientation="vertical"
            android:padding="28dp"
            android:visibility="gone">

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center"
                android:text="Nenhuma contagem disponível"
                android:textColor="@color/counter_text"
                android:textSize="17sp"
                android:textStyle="bold" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="6dp"
                android:gravity="center"
                android:text="Toque em Atualizar para buscar as contagens liberadas para este usuário."
                android:textColor="@color/counter_muted"
                android:textSize="14sp" />
        </LinearLayout>
    </FrameLayout>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@color/counter_background"
        android:elevation="8dp"
        android:gravity="center"
        android:orientation="horizontal"
        android:padding="12dp">

        <Button
            android:id="@+id/button_refresh_bottom"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginEnd="8dp"
            android:layout_weight="1"
            android:background="@drawable/bg_button_primary"
            android:text="Atualizar"
            android:textAllCaps="false"
            android:textColor="@android:color/white"
            android:textStyle="bold" />

        <Button
            android:id="@+id/button_logout_bottom"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="8dp"
            android:layout_weight="1"
            android:background="@drawable/bg_button_secondary"
            android:text="Sair"
            android:textAllCaps="false"
            android:textColor="@color/counter_text"
            android:textStyle="bold" />
    </LinearLayout>
</LinearLayout>
