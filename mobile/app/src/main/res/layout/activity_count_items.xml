<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/counter_surface"
    android:orientation="vertical">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@color/counter_background"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:padding="16dp">

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical">

            <TextView
                android:id="@+id/text_title"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:textColor="@color/counter_text"
                android:textSize="20sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/text_status"
                android:layout_width="1dp"
                android:layout_height="1dp"
                android:visibility="gone"
                android:textColor="@color/counter_muted"
                android:textSize="13sp" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="6dp"
                android:gravity="center_vertical"
                android:orientation="horizontal">

                <View
                    android:id="@+id/view_status_dot"
                    android:layout_width="9dp"
                    android:layout_height="9dp"
                    android:layout_marginEnd="8dp"
                    android:background="@drawable/bg_status_open" />

                <TextView
                    android:id="@+id/text_status_label"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textColor="@color/counter_muted"
                    android:textSize="13sp" />
            </LinearLayout>
        </LinearLayout>

        <Button
            android:id="@+id/button_sync"
            android:layout_width="1dp"
            android:layout_height="1dp"
            android:background="@drawable/bg_button_primary"
            android:minWidth="0dp"
            android:visibility="gone"
            android:text="Sincronizar"
            android:textAllCaps="false"
            android:textColor="@android:color/white" />
    </LinearLayout>

    <EditText
        android:id="@+id/edit_search"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginStart="16dp"
        android:layout_marginTop="14dp"
        android:layout_marginEnd="16dp"
        android:background="@drawable/bg_input"
        android:hint="Buscar por nome, SKU ou código de barras"
        android:inputType="text"
        android:singleLine="true"
        android:textColor="@color/counter_text"
        android:textColorHint="@color/counter_muted" />

    <FrameLayout
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1">

        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/recycler_items"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:clipToPadding="false"
            android:padding="16dp" />

        <LinearLayout
            android:id="@+id/layout_loading_items"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:background="@color/counter_surface"
            android:gravity="center"
            android:orientation="vertical"
            android:padding="24dp"
            android:visibility="gone">

            <ProgressBar
                android:layout_width="44dp"
                android:layout_height="44dp"
                android:indeterminate="true" />

            <TextView
                android:id="@+id/text_loading_items"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:text="Sincronizando itens..."
                android:textColor="@color/counter_muted"
                android:textSize="14sp" />
        </LinearLayout>

        <LinearLayout
            android:id="@+id/layout_empty_items"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:gravity="center"
            android:orientation="vertical"
            android:padding="28dp"
            android:visibility="gone">

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center"
                android:text="Nenhum item disponível"
                android:textColor="@color/counter_text"
                android:textSize="17sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/text_empty_items"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="6dp"
                android:gravity="center"
                android:text="Atualize ou volte para escolher outra contagem."
                android:textColor="@color/counter_muted"
                android:textSize="14sp" />
        </LinearLayout>
    </FrameLayout>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@color/counter_background"
        android:elevation="8dp"
        android:gravity="center"
        android:orientation="horizontal"
        android:padding="12dp">

        <Button
            android:id="@+id/button_back"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginEnd="8dp"
            android:layout_weight="1"
            android:background="@drawable/bg_button_secondary"
            android:text="Voltar"
            android:textAllCaps="false"
            android:textColor="@color/counter_text"
            android:textStyle="bold" />

        <Button
            android:id="@+id/button_sync_bottom"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="8dp"
            android:layout_weight="1"
            android:background="@drawable/bg_button_primary"
            android:text="Sincronizar"
            android:textAllCaps="false"
            android:textColor="@android:color/white"
            android:textStyle="bold" />
    </LinearLayout>
</LinearLayout>
